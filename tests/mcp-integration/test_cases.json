{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Integration Test Cases",
  "description": "Test cases for verifying MCP server integration using MCP Inspector CLI",
  "version": "2.0.0",

  "discovery": {
    "description": "Tests that verify MCP server discovery without requiring OpenROAD",
    "requires": [],
    "tests": [
      {
        "name": "list_tools",
        "description": "Verify all MCP tools are discoverable",
        "method": "tools/list",
        "expect_contains": [
          "interactive_openroad",
          "create_interactive_session",
          "terminate_interactive_session",
          "list_interactive_sessions",
          "get_session_metrics",
          "inspect_interactive_session",
          "get_session_history"
        ],
        "timeout_seconds": 30
      },
      {
        "name": "get_metrics",
        "description": "Verify get_session_metrics returns valid response",
        "method": "tools/call",
        "tool_name": "get_session_metrics",
        "tool_args": {},
        "expect_contains": ["active_sessions", "total_sessions"],
        "timeout_seconds": 30
      },
      {
        "name": "list_sessions",
        "description": "Verify list_interactive_sessions returns valid response",
        "method": "tools/call",
        "tool_name": "list_interactive_sessions",
        "tool_args": {},
        "expect_contains": ["sessions"],
        "timeout_seconds": 30
      }
    ]
  },

  "session": {
    "description": "Tests that verify interactive session functionality (requires OpenROAD)",
    "requires": ["openroad"],
    "setup": {
      "ensure_no_test_sessions": "Terminate any existing sessions with test- prefix"
    },
    "teardown": {
      "cleanup_test_sessions": "Terminate all sessions created during tests"
    },
    "tests": [
      {
        "name": "create_session",
        "description": "Verify session creation",
        "method": "tools/call",
        "tool_name": "create_interactive_session",
        "tool_args_template": {"session_id": "{session_id}"},
        "expect_contains": ["session_id"],
        "timeout_seconds": 60
      },
      {
        "name": "execute_simple_command",
        "description": "Verify basic command execution",
        "method": "tools/call",
        "tool_name": "interactive_openroad",
        "tool_args_template": {"session_id": "{session_id}", "command": "puts hello"},
        "expect_contains": ["hello"],
        "timeout_seconds": 30
      },
      {
        "name": "execute_math_command",
        "description": "Verify mathematical command execution",
        "method": "tools/call",
        "tool_name": "interactive_openroad",
        "tool_args_template": {"session_id": "{session_id}", "command": "expr 2 + 2"},
        "expect_contains": ["4"],
        "timeout_seconds": 30
      },
      {
        "name": "get_history",
        "description": "Verify session history retrieval",
        "method": "tools/call",
        "tool_name": "get_session_history",
        "tool_args_template": {"session_id": "{session_id}"},
        "expect_contains": ["puts", "expr"],
        "timeout_seconds": 30
      },
      {
        "name": "inspect_session",
        "description": "Verify session inspection",
        "method": "tools/call",
        "tool_name": "inspect_interactive_session",
        "tool_args_template": {"session_id": "{session_id}"},
        "expect_contains": ["session_id", "state"],
        "timeout_seconds": 30
      },
      {
        "name": "list_sessions_after_create",
        "description": "Verify session appears in list",
        "method": "tools/call",
        "tool_name": "list_interactive_sessions",
        "tool_args_template": {},
        "expect_contains_template": ["{session_id}"],
        "timeout_seconds": 30
      },
      {
        "name": "terminate_session",
        "description": "Verify session termination",
        "method": "tools/call",
        "tool_name": "terminate_interactive_session",
        "tool_args_template": {"session_id": "{session_id}"},
        "expect_contains": ["terminated", "success"],
        "timeout_seconds": 30
      },
      {
        "name": "verify_session_gone",
        "description": "Verify session no longer exists after termination",
        "method": "tools/call",
        "tool_name": "list_interactive_sessions",
        "tool_args_template": {},
        "expect_not_contains_template": ["{session_id}"],
        "timeout_seconds": 30
      }
    ]
  },

  "report_images": {
    "description": "Tests for report image functionality",
    "requires": ["orfs_data"],
    "tests": [
      {
        "name": "list_report_images",
        "description": "List available report images",
        "method": "tools/call",
        "tool_name": "list_report_images",
        "tool_args": {"platform": "asap7", "design": "gcd", "run_slug": "base"},
        "expect_any": ["platforms", "designs", "no reports", "empty"],
        "timeout_seconds": 30
      }
    ]
  },

  "error_handling": {
    "description": "Tests for error handling and edge cases",
    "requires": [],
    "tests": [
      {
        "name": "invalid_session_operation",
        "description": "Verify error handling for non-existent session",
        "method": "tools/call",
        "tool_name": "inspect_interactive_session",
        "tool_args": {"session_id": "nonexistent-session-xyz"},
        "expect_contains": ["error", "not found"],
        "timeout_seconds": 30
      },
      {
        "name": "terminate_nonexistent_session",
        "description": "Verify error handling when terminating non-existent session",
        "method": "tools/call",
        "tool_name": "terminate_interactive_session",
        "tool_args": {"session_id": "nonexistent-session-xyz"},
        "expect_contains": ["error", "not found"],
        "timeout_seconds": 30
      }
    ]
  }
}
